3) Create: assets/theme.scss
(ALA Labs-inspired: whitespace, hero, simple nav, card grids, subtle borders, Illinois hover accent)
----- BEGIN assets/theme.scss -----
$illini-blue: #13294B;
$illini-orange: #FF5F05;
$fog: #F6F7F9;
$border: #E5E7EB;

body {
  color: $illini-blue;
}

a {
  color: $illini-blue;
  text-decoration-thickness: 2px;
  text-underline-offset: 3px;
}
a:hover { color: $illini-orange; }

/* Minimal navbar */
.navbar {
  border-bottom: 1px solid $border;
}
.navbar .navbar-brand,
.navbar a.nav-link {
  font-family: "Montserrat", sans-serif;
  font-weight: 600;
}
.navbar a.nav-link:hover { color: $illini-orange !important; }

/* Editorial headings like ALA Labs */
h1, h2, h3 { letter-spacing: -0.02em; }
h1 { font-size: clamp(2.3rem, 3.2vw, 3.2rem); margin-top: 0.4rem; }
h2 { margin-top: 2.2rem; }

/* Hero block */
.hero {
  padding: 1.2rem 0 0.4rem 0;
}
.hero .subtitle {
  font-size: 1.15rem;
  color: rgba(19, 41, 75, 0.80);
  max-width: 60rem;
}

/* Soft section bands */
.section-band {
  background: $fog;
  border: 1px solid $border;
  border-radius: 18px;
  padding: 1.25rem 1.25rem;
  margin: 1.25rem 0;
}

/* Card feel for listings/grids */
.card, .quarto-grid-item, .quarto-listing-card {
  border: 1px solid $border !important;
  border-radius: 16px !important;
  box-shadow: none !important;
}
.card:hover, .quarto-grid-item:hover, .quarto-listing-card:hover {
  border-color: rgba(255, 95, 5, 0.35) !important;
}
----- END assets/theme.scss -----

